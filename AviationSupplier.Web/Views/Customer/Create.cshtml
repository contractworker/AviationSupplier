@model Customer

@{
    ViewData["Title"] = "Create Customer";
}

<div class="container">

    <h3>Customer</h3>

    <form method="post" action="/Customer/Create">

        <!-- Customer Info -->
        <div class="row mb-3">
            <div class="col-md-6">
                <label>Company Name</label>
                <input asp-for="CompanyName" class="form-control" />
            </div>

            <div class="col-md-6">
                <label>Contact Name</label>
                <input asp-for="ContactName" class="form-control" />
            </div>
        </div>

        <!-- Addresses Section -->
        <div class="d-flex justify-content-between align-items-center mt-4">
            <h4>Addresses</h4>
            <button type="button" class="btn btn-success" id="btnAddAddress">
                Add Address
            </button>
        </div>

        <table class="table table-bordered mt-2" id="addressTable">
            <thead class="table-light">
                <tr>
                    <th>Company</th>
                    <th>Contact</th>
                    <th>City</th>
                    <th>Phone</th>
                    <th style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <!-- Hidden container for posting addresses -->
        <div id="addressInputs"></div>

        <button type="submit" class="btn btn-primary mt-3">Save</button>

    </form>

</div>

<!-- Modal -->
<div class="modal fade" id="addressModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="addressIndex" />

                <div class="mb-2">
                    <label>Company</label>
                    <input type="text" id="addrCompany" class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Contact</label>
                    <input type="text" id="addrContact" class="form-control" />
                </div>

                <div class="mb-2">
                    <label>City</label>
                    <input type="text" id="addrCity" class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Phone</label>
                    <input type="text" id="addrPhone" class="form-control" />
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="saveAddress">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>
