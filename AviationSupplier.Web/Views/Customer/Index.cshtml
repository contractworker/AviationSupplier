@{
    ViewData["Title"] = "Customers";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Customers</h2>
        <a href="/Customer/Create" class="btn btn-primary">
            <i class="bi bi-plus"></i> Add Customer
        </a>
    </div>

    <!-- Search -->
    <div class="row mb-3">
        <div class="col-md-4">
            <input type="text"
                   id="searchBox"
                   class="form-control"
                   placeholder="Search by name, email, city..." />
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover" id="customerTable">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px;">Id</th>
                    <th>Company Name</th>
                    <th>Contact</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th style="width:160px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Filled by jQuery -->
            </tbody>
        </table>
    </div>

</div>

@section Scripts {

    <!-- jQuery (ensure it's loaded once in layout ideally) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Customer module -->
    <script src="~/js/customer.js"></script>

    <!-- Init -->
    <script>
        $(document).ready(function () {
            CustomerModule.init();
        });
    </script>
}