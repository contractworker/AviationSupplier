<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"]</title>   
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://use.fontawesome.com/releases/v5.0.6/css/all.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.css" />

    <link rel="stylesheet" type="text/css" href="~/css/style.css">
  
</head>
<body>
    <div class="page-wrapper chiller-theme toggled-sm toggled">
       
        <!-- sidebar starts -->
        <a id="show-sidebar" class="btn btn-sm btn-dark" href="#"> <i class="fas fa-bars"></i> </a>
        <nav id="sidebar" class="sidebar-wrapper">
            <div class="sidebar-content">
                <div class="sidebar-brand">
                    <a href="#">Menu</a>
                    <div id="close-sidebar"> <i class="fas fa-times"></i> </div>
                </div>
                <!-- sidebar-menu  -->
                <div class="sidebar-menu">
                    <ul>
                        <li class="sidebar-dropdown">
                            <a href="#"> <i class="fa fa-tachometer-alt"></i> <span>Dashboard</span></a>
                            <div class="sidebar-submenu">
                                <ul>
                                    <li><a asp-area="admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a> </li>
                                </ul>
                            </div>
                        </li>
                       
                        <li class="sidebar-dropdown">
                            <a href="#"> <i class="fas fa-bus"></i> <span>Customer</span> </a>
                            <div class="sidebar-submenu">
                                <ul>
                                    <li><a href="/customer">Customers</a></li>
                                    <li><a href="/customer/create">Add</a></li>
                                </ul>
                            </div>
                        </li>
                    </ul>
                </div>
                <!-- sidebar-menu  -->
            </div>
            <!-- sidebar-content  -->
        </nav>
        <!-- sidebar ends -->

        <!-- sidebar-wrapper  -->
        <main class="page-content">
            <div class="container-fluid">
                <header id="aa-header">
                    <div class="aa-header-bottom">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="aa-header-bottom-area">
                                    <!-- logo  -->
                                    <div class="aa-logo">
                                    </div>
                                    <!-- / logo  -->
                                    <div class="aa-search-box hidden-xs"> <a href="#">Logout</a></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>
                <section id="menu">
                    <div class="menu-area">
                        <!-- Navbar -->
                        <div class="navbar navbar-default">
                            <div class="navbar-collapse  pl-0" style="text-align:center;">
                                <!-- Left nav -->
                                <div style="color: white; font-weight: bold; ">@ViewBag.Heading</div>
                            </div>
                        </div>
                    </div>
                </section>
                <section id="page-content">

                    @RenderBody()
                </section>
                <div class="clearfix"></div>
               @*  <footer id="aa-footer">
                    <div class="aa-footer-bottom">
                        <div class="container">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="aa-footer-bottom-area">
                                        <p>© Copyright <a href="#">All rights reserved.</a></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </footer> *@
            </div>
        </main>
        <!-- page-content" -->

    </div>
    <!-- page-wrapper -->
    @*<partial name="_Model" />*@

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @* <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.2.1/jquery.min.js"></script> *@
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.2/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
    
    <script src="~/js/site.js"></script>

    <script>
        var settings = {
            validClass: "is-valid",
            errorClass: "is-invalid"
            //validClass: "valid-feedback",
            //errorClass: "invalid-feedback"
        };
        $.validator.setDefaults(settings);
        $.validator.unobtrusive.options = settings;
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>